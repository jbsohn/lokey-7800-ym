
(rules PCB index.dsn
  (snap_angle 
    fortyfive_degree
  )
  (rule
    (width 100.0)
    (clearance 100.0)
    (clearance 50.0 (type smd_to_turn_gap))
    (clearance 25.0 (type smd))
    (clearance 100.0 (type "kicad_default"))
  )
  (padstack "Via[0-1]_300:200_um"
    (shape
      (circle F.Cu 300.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 300.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-1]_300:200_um" "Via[0-1]_300:200_um" default
  )
  (via 
    "Via[0-1]_300:200_um-kicad_default" "Via[0-1]_300:200_um" "kicad_default"
  )
  (via_rule
    default "Via[0-1]_300:200_um"
  )
  (via_rule
    "kicad_default" "Via[0-1]_300:200_um-kicad_default"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 100.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class "kicad_default"
    GND VCC A3 A4 A5 A6 A7 A8
    A9 A10 A11 A12 A0 A15 D1 D2
    D3 D4 D5 D6 D7 RW PHI2 D0
    "SUM_NODE" "ROM_CE" BDIR BC1 PHI2OUT "YM_LE" DA0 DA1
    DA2 DA3 A13 DA4 DA5 DA6 DA7 "RESET_DELAYED"
    "ANALOG_A" "ANALOG_B" "ANALOG_C" "OPAMP_FB" "U5_UNUSED_FB" A14 "CAP_PLUS" HALT
    A1 A2
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 100.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
)